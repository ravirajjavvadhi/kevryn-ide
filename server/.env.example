# Server Configuration
PORT=5000
NODE_ENV=production

# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/ide_db?retryWrites=true&w=majority

# JWT
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING

# Session
SESSION_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=https://yourdomain.com/auth/github/callback

# Groq AI
GROQ_API_KEY=gsk_your_groq_api_key

# Client URL (for OAuth redirects and CORS)
CLIENT_URL=https://yourdomain.com
CORS_ORIGIN=https://yourdomain.com
